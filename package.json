{
  "name": "chetana",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "setup": "bash scripts/setup.sh",
    "audit": "tsx scripts/run-audit.ts",
    "db:migrate": "cd packages/supabase && supabase db push",
    "db:reset": "cd packages/supabase && supabase db reset"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.2",
    "tsx": "^4.21.0",
    "turbo": "^2.4.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.2"
  },
  "packageManager": "pnpm@9.15.0"
}
