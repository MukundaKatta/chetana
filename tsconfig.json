{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true
  },
  "//": "apps/web has its own Next-aware tsconfig (jsx + next plugin) and is typechecked by `next build`; excluding it here keeps the root typecheck scoped to the shared packages and scripts.",
  "exclude": ["apps/web", "**/node_modules", "**/dist"]
}
